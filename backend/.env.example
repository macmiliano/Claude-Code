# MathClash backend environment (optional)
# -----------------------------------------------------------------------------
# Copy this file to `backend/.env` and fill in values to enable accounts/login.
# Leave everything unset to run guest-only — the game works fine without a DB.

# HTTP / WebSocket port (default 4000)
# PORT=4000

# CORS allow-list for the frontend origin ("*" is fine for single-origin deploys)
# CLIENT_ORIGIN=*

# --- Optional accounts / Google login / leaderboard --------------------------
# PostgreSQL connection string (Neon / Supabase / Render Postgres).
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Google OAuth 2.0 *Web* client id (no client secret needed).
# Create at https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com

# Secret used to sign session JWTs. Generate with: openssl rand -hex 32
# JWT_SECRET=change-me-to-a-long-random-string
